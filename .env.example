# Required for real mode
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
WALLET_KEYPAIR_PATH=./keys/operator.json

# Jito block engine
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_UUID=

# Optional Yellowstone/Geyser provider. If not set, the stack can still run
# dry-run mode and can use Solana websocket slot notifications as a fallback.
YELLOWSTONE_ENDPOINT=
YELLOWSTONE_X_TOKEN=

# AI agent. If unset, the stack uses the deterministic local policy and logs
# the exact factors it considered.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Runtime knobs
NETWORK=mainnet-beta
DRY_RUN=true
LOG_DIR=logs
